generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider                = "mysql"
  url                     = env("DATABASE_URL")
}

model User {
  id              Int               @id @default(autoincrement())
  name            String            @unique
  email           String?           @unique
  password        String?
  lastLogin       DateTime?         @updatedAt

  // Relation Fields
  userRole        UserRole[]
}

model Role {
  id              Int               @id @default(autoincrement())
  name            String            @unique

  // Relation Fields
  userRole        UserRole[]
  access          Access[]
}

model UserRole {
  // Relation Fields
  user            User              @relation(fields: [userName], references: [name], onDelete: Cascade, onUpdate: Cascade)
  userName        String            @id
  role            Role              @relation(fields: [roleName], references: [name], onDelete: Cascade, onUpdate: Cascade)
  roleName        String
}

model Access {
  path            String            @unique

  // Relation Fields
  role            Role              @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  roleId          Int
}

model Inquiry {
  id              Int               @id @default(autoincrement())
  name            String            @unique

  // Relation Fields
  message         Contact[]
}

model Contact {
  id              Int               @id @default(autoincrement())
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  name            String
  email           String
  phone           String
  message         String            @db.Text

  // Relation Fields
  inquiry         Inquiry           @relation(fields: [inquiryId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  inquiryId       Int
}
